#!/usr/bin/env bash
set -euo pipefail

info() { printf '[INFO] %s\n' "$*"; }
ok() { printf '[OK] %s\n' "$*"; }
die() { printf '[ERROR] %s\n' "$*" >&2; exit 1; }

usage() {
  cat >&2 <<'USAGE'
Usage: platform-ssh-init [ssh-config.env] [options]

Options:
  --key-path <path>     Private key path to create or reuse.
  --comment <text>      Comment stored in the generated public key.
  --host <host>         SSH host/IP for an SSH config block.
  --user <user>         SSH user. Default: current user.
  --alias <alias>       SSH config Host alias. Requires --host.
  --test-command <cmd>  Remote command used by --test. Default: hostname.
  --empty-passphrase    Create a key without prompting for a passphrase.
  --write-config        Append the SSH Host block to ~/.ssh/config.
  --test                Test SSH access using SSH_TEST_COMMAND or hostname.
  --print-public-key    Print the generated public key.
  -h, --help            Show this help.

Config variables:
  SSH_KEY_PATH          Required private key path.
  SSH_KEY_COMMENT       Optional key comment.
  SSH_HOST              Optional SSH host/IP for an SSH config block.
  SSH_USER              Optional SSH user. Default: current user.
  SSH_ALIAS             Optional SSH config Host alias.
  SSH_TEST_COMMAND      Optional remote command for --test.

This tool creates only local SSH client material. It does not install public
keys on remote hosts, create users, create API tokens, or edit application
configuration files.

CLI flags override values loaded from the optional config file.
USAGE
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

expand_path() {
  case $1 in
    \~) printf '%s\n' "$HOME" ;;
    \~/*) printf '%s/%s\n' "$HOME" "${1:2}" ;;
    *) printf '%s\n' "$1" ;;
  esac
}

trim_space() {
  local value=$1

  value=${value#"${value%%[![:space:]]*}"}
  value=${value%"${value##*[![:space:]]}"}
  printf '%s\n' "$value"
}

expand_config_value() {
  local value=$1

  value=${value//\$\{HOME\}/$HOME}
  value=${value//\$HOME/$HOME}
  case $value in
    \~) value=$HOME ;;
    \~/*) value=${HOME}/${value:2} ;;
  esac
  printf '%s\n' "$value"
}

parse_config_value() {
  local value=$1
  local first last

  value=$(trim_space "$value")
  first=${value:0:1}
  last=${value: -1}

  if [[ "$first" == '"' || "$first" == "'" ]]; then
    [[ "$last" == "$first" ]] || die 'Config value has an unmatched quote'
    value=${value:1:${#value}-2}
  fi

  expand_config_value "$value"
}

set_config_var() {
  local name=$1
  local value=$2

  case $name in
    SSH_KEY_PATH|SSH_KEY_COMMENT|SSH_HOST|SSH_USER|SSH_ALIAS|SSH_TEST_COMMAND)
      printf -v "$name" '%s' "$value"
      ;;
    *)
      die "Unsupported config variable in ${CONFIG_FILE}: ${name}"
      ;;
  esac
}

load_config_file() {
  local line_number=0
  local line name value

  while IFS= read -r line || [[ -n "$line" ]]; do
    line_number=$((line_number + 1))
    line=${line%$'\r'}
    line=$(trim_space "$line")

    [[ -z "$line" ]] && continue
    [[ "${line:0:1}" == '#' ]] && continue

    case $line in
      export[[:space:]]*)
        line=$(trim_space "${line#export}")
        ;;
    esac

    [[ "$line" == *=* ]] || die "Invalid config line ${line_number} in ${CONFIG_FILE}: expected NAME=value"
    name=$(trim_space "${line%%=*}")
    value=${line#*=}
    [[ "$name" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || die "Invalid config variable name on line ${line_number} in ${CONFIG_FILE}: ${name}"
    set_config_var "$name" "$(parse_config_value "$value")"
  done <"$CONFIG_FILE"
}

require_var() {
  local name=$1
  if [[ -z "${!name:-}" ]]; then
    die "Required config variable ${name} is missing or empty"
  fi
}

has_host_config() {
  [[ -n "${SSH_HOST:-}" && -n "${SSH_ALIAS:-}" ]]
}

print_ssh_config() {
  require_var SSH_HOST
  require_var SSH_ALIAS

  printf 'Host %s\n' "$SSH_ALIAS"
  printf '  HostName %s\n' "$SSH_HOST"
  printf '  User %s\n' "$SSH_USER"
  printf '  IdentityFile %s\n' "$SSH_KEY_PATH"
  printf '  IdentitiesOnly yes\n'
}

host_alias_exists() {
  local config_file=$1
  local alias=$2

  [[ -f "$config_file" ]] || return 1
  awk -v alias="$alias" '
    /^[[:space:]]*Host[[:space:]]+/ {
      for (i = 2; i <= NF; i++) {
        if ($i == alias) {
          found = 1
        }
      }
    }
    END { exit found ? 0 : 1 }
  ' "$config_file"
}

write_ssh_config() {
  local ssh_dir=$1
  local config_file=$2

  has_host_config || die '--write-config requires SSH_HOST and SSH_ALIAS from the config file or CLI flags'

  mkdir -p "$ssh_dir"
  chmod 700 "$ssh_dir"
  touch "$config_file"
  chmod 600 "$config_file"

  if host_alias_exists "$config_file" "$SSH_ALIAS"; then
    die "SSH config already contains Host ${SSH_ALIAS}; edit ${config_file} manually or choose another SSH_ALIAS"
  fi

  {
    printf '\n'
    print_ssh_config
  } >>"$config_file"

  ok "Wrote SSH config alias ${SSH_ALIAS} to ${config_file}"
}

test_connection() {
  require_var SSH_HOST
  command_exists ssh || die 'ssh is required for --test'

  local test_command=${SSH_TEST_COMMAND:-hostname}
  info "Testing SSH access to ${SSH_USER}@${SSH_HOST}"
  # SSH_TEST_COMMAND is intentionally expanded locally from trusted config or CLI input.
  # shellcheck disable=SC2029
  ssh -i "$KEY_PATH" -o IdentitiesOnly=yes "${SSH_USER}@${SSH_HOST}" "$test_command"
  ok "SSH access test succeeded"
}

EMPTY_PASSPHRASE='false'
WRITE_CONFIG='false'
RUN_TEST='false'
PRINT_PUBLIC_KEY='false'
CONFIG_FILE=''
CLI_SSH_KEY_PATH=''
CLI_SSH_KEY_COMMENT=''
CLI_SSH_HOST=''
CLI_SSH_USER=''
CLI_SSH_ALIAS=''
CLI_SSH_TEST_COMMAND=''

while [[ $# -gt 0 ]]; do
  case $1 in
    --key-path)
      [[ $# -ge 2 ]] || die '--key-path requires a value'
      CLI_SSH_KEY_PATH=$2
      shift 2
      ;;
    --comment)
      [[ $# -ge 2 ]] || die '--comment requires a value'
      CLI_SSH_KEY_COMMENT=$2
      shift 2
      ;;
    --host)
      [[ $# -ge 2 ]] || die '--host requires a value'
      CLI_SSH_HOST=$2
      shift 2
      ;;
    --user)
      [[ $# -ge 2 ]] || die '--user requires a value'
      CLI_SSH_USER=$2
      shift 2
      ;;
    --alias)
      [[ $# -ge 2 ]] || die '--alias requires a value'
      CLI_SSH_ALIAS=$2
      shift 2
      ;;
    --test-command)
      [[ $# -ge 2 ]] || die '--test-command requires a value'
      CLI_SSH_TEST_COMMAND=$2
      shift 2
      ;;
    --empty-passphrase)
      EMPTY_PASSPHRASE='true'
      shift
      ;;
    --write-config)
      WRITE_CONFIG='true'
      shift
      ;;
    --test)
      RUN_TEST='true'
      shift
      ;;
    --print-public-key)
      PRINT_PUBLIC_KEY='true'
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    -*)
      die "Unknown option: $1"
      ;;
    *)
      [[ -z "$CONFIG_FILE" ]] || die 'Only one config file may be provided'
      CONFIG_FILE=$1
      shift
      ;;
  esac
done

if [[ -n "$CONFIG_FILE" ]]; then
  [[ -f "$CONFIG_FILE" ]] || die "Config file not found: ${CONFIG_FILE}"
  load_config_file
fi

[[ -z "$CLI_SSH_KEY_PATH" ]] || SSH_KEY_PATH=$CLI_SSH_KEY_PATH
[[ -z "$CLI_SSH_KEY_COMMENT" ]] || SSH_KEY_COMMENT=$CLI_SSH_KEY_COMMENT
[[ -z "$CLI_SSH_HOST" ]] || SSH_HOST=$CLI_SSH_HOST
[[ -z "$CLI_SSH_USER" ]] || SSH_USER=$CLI_SSH_USER
[[ -z "$CLI_SSH_ALIAS" ]] || SSH_ALIAS=$CLI_SSH_ALIAS
[[ -z "$CLI_SSH_TEST_COMMAND" ]] || SSH_TEST_COMMAND=$CLI_SSH_TEST_COMMAND

if [[ -z "${SSH_KEY_PATH:-}" ]]; then
  usage
  die 'SSH_KEY_PATH is required; provide a config file or --key-path'
fi

require_var SSH_KEY_PATH
SSH_USER=${SSH_USER:-$(id -un)}
SSH_KEY_COMMENT=${SSH_KEY_COMMENT:-platform-ssh-init}

command_exists ssh-keygen || die 'ssh-keygen is required'

KEY_PATH=$(expand_path "$SSH_KEY_PATH")
KEY_DIR=$(dirname -- "$KEY_PATH")
SSH_CONFIG_FILE="${HOME}/.ssh/config"

mkdir -p "$KEY_DIR"
chmod 700 "$KEY_DIR"

if [[ -e "$KEY_PATH" ]]; then
  [[ -f "$KEY_PATH" ]] || die "SSH key path exists but is not a regular file: ${KEY_PATH}"
  chmod 600 "$KEY_PATH"
  ok "SSH key already exists: ${KEY_PATH}"
else
  info "Creating dedicated ed25519 SSH key: ${KEY_PATH}"
  if [[ "$EMPTY_PASSPHRASE" == 'true' ]]; then
    ssh-keygen -t ed25519 -a 100 -N '' -f "$KEY_PATH" -C "$SSH_KEY_COMMENT"
  else
    ssh-keygen -t ed25519 -a 100 -f "$KEY_PATH" -C "$SSH_KEY_COMMENT"
  fi
  chmod 600 "$KEY_PATH"
  ok "Created SSH key: ${KEY_PATH}"
fi

if [[ ! -f "${KEY_PATH}.pub" ]]; then
  info "Creating missing public key: ${KEY_PATH}.pub"
  ssh-keygen -y -f "$KEY_PATH" >"${KEY_PATH}.pub"
  chmod 644 "${KEY_PATH}.pub"
  ok "Created public key: ${KEY_PATH}.pub"
else
  chmod 644 "${KEY_PATH}.pub"
fi

if has_host_config; then
  printf '\nSSH config block:\n\n'
  print_ssh_config

  printf '\nInstall the public key on the remote host if needed:\n\n'
  printf 'ssh-copy-id -i %s.pub %s@%s\n' "$SSH_KEY_PATH" "$SSH_USER" "$SSH_HOST"
fi

if [[ "$WRITE_CONFIG" == 'true' ]]; then
  write_ssh_config "${HOME}/.ssh" "$SSH_CONFIG_FILE"
elif has_host_config; then
  printf '\nRun again with --write-config to append this Host block to %s.\n' "$SSH_CONFIG_FILE"
fi

if [[ "$PRINT_PUBLIC_KEY" == 'true' ]]; then
  printf '\nPublic key:\n\n'
  sed -n '1p' "${KEY_PATH}.pub"
fi

if [[ "$RUN_TEST" == 'true' ]]; then
  test_connection
elif [[ -n "${SSH_HOST:-}" ]]; then
  printf '\nAfter installing the public key, test access with:\n\n'
  printf "ssh -i %s -o IdentitiesOnly=yes %s@%s '%s'\n" "$KEY_PATH" "$SSH_USER" "$SSH_HOST" "${SSH_TEST_COMMAND:-hostname}"
fi
