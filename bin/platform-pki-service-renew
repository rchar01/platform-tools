#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)
COMMON_PATH=${PLATFORM_TOOLS_LIB_DIR:-}
if [[ -n "$COMMON_PATH" ]]; then COMMON_PATH=${COMMON_PATH}/platform-pki-common.sh; elif [[ -r "${SCRIPT_DIR}/../lib/platform-pki-common.sh" ]]; then COMMON_PATH=${SCRIPT_DIR}/../lib/platform-pki-common.sh; else COMMON_PATH=${PLATFORM_TOOLS_SHARE_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/platform-tools}/lib/platform-pki-common.sh; fi
[[ -r "$COMMON_PATH" ]] || { printf '[ERROR] platform-pki-common.sh not found\n' >&2; exit 1; }
# shellcheck source=../lib/platform-pki-common.sh disable=SC1091
source "$COMMON_PATH"

usage() {
  cat >&2 <<'USAGE'
Usage: platform-pki-service-renew <service> [options]

Renew a service certificate from inventory/services.yml using the intermediate CA.

Options:
  --namespace <path>  Platform namespace root. Default: ~/.config/platform-infrastructure
  --pki-dir <path>    PKI directory. Default: <namespace>/pki
  --days <days>       Override service certificate lifetime.
  --intermediate-pass-file <path>
                      Read encrypted intermediate key passphrase from file.
  --rotate-key        Archive and replace the existing service private key.
  -h, --help          Show this help.
USAGE
}

archive_if_exists() {
  local path=$1
  local target_name=$2

  [[ -e "$path" ]] || return 0
  mv "$path" "$ARCHIVE_DIR/$target_name"
  pki_info "Archived $path to $ARCHIVE_DIR/$target_name"
}

NAMESPACE=$(pki_default_namespace)
PKI_DIR=''
SERVICE=''
DAYS=''
ROTATE_KEY=false
INTERMEDIATE_PASS_FILE=''

while [[ $# -gt 0 ]]; do
  case $1 in
    --namespace) [[ $# -ge 2 ]] || pki_die '--namespace requires a value'; NAMESPACE=$2; shift 2 ;;
    --pki-dir) [[ $# -ge 2 ]] || pki_die '--pki-dir requires a value'; PKI_DIR=$2; shift 2 ;;
    --days) [[ $# -ge 2 ]] || pki_die '--days requires a value'; DAYS=$2; shift 2 ;;
    --intermediate-pass-file) [[ $# -ge 2 ]] || pki_die '--intermediate-pass-file requires a value'; INTERMEDIATE_PASS_FILE=$2; shift 2 ;;
    --rotate-key) ROTATE_KEY=true; shift ;;
    -h|--help) usage; exit 0 ;;
    --*) pki_die "Unknown argument: $1" ;;
    *)
      [[ -z "$SERVICE" ]] || pki_die "Unexpected extra argument: $1"
      SERVICE=$1
      shift
      ;;
  esac
done

[[ -n "$SERVICE" ]] || pki_die 'service name is required'
pki_validate_service_name "$SERVICE"
NAMESPACE=$(pki_expand_path "$NAMESPACE")
PKI_DIR=${PKI_DIR:-${NAMESPACE}/pki}
PKI_DIR=$(pki_expand_path "$PKI_DIR")
if [[ -n "$INTERMEDIATE_PASS_FILE" ]]; then
  INTERMEDIATE_PASS_FILE=$(pki_expand_path "$INTERMEDIATE_PASS_FILE")
  pki_require_pass_file "$INTERMEDIATE_PASS_FILE"
fi

pki_require_cmd openssl
pki_require_pki_dir
pki_require_service_in_inventory "$SERVICE"
pki_require_file "$(pki_intermediate_key)"
pki_require_file "$(pki_intermediate_cert)"
pki_require_file "$(pki_root_cert)"

COMMON_NAME=$(pki_inventory_scalar "$SERVICE" common_name)
[[ -n "$COMMON_NAME" ]] || pki_die "common_name is missing for service: $SERVICE"
if [[ -z "$DAYS" ]]; then
  DAYS=$(pki_inventory_scalar "$SERVICE" days)
fi
DAYS=${DAYS:-${PLATFORM_PKI_SERVICE_DAYS:-397}}
pki_validate_days "$DAYS"

SERVICE_DIR=$(pki_service_dir "$SERVICE")
KEY=$(pki_service_key "$SERVICE")
CSR="$SERVICE_DIR/csr/tls.csr"
CERT=$(pki_service_cert "$SERVICE")
CHAIN=$(pki_service_chain "$SERVICE")
FULLCHAIN=$(pki_service_fullchain "$SERVICE")
CONF="$SERVICE_DIR/openssl.cnf"
ARCHIVE_DIR=$(pki_new_service_archive_dir "$SERVICE")
DNS_FILE=$(mktemp)
IPS_FILE=$(mktemp)
trap 'rm -f "$DNS_FILE" "$IPS_FILE"' EXIT

pki_inventory_array "$SERVICE" dns >"$DNS_FILE"
pki_inventory_array "$SERVICE" ips >"$IPS_FILE"
if [[ ! -s "$DNS_FILE" && ! -s "$IPS_FILE" ]]; then
  pki_die "Service must define at least one DNS or IP SAN: $SERVICE"
fi

for dir in "$SERVICE_DIR" "$SERVICE_DIR/private" "$SERVICE_DIR/csr" "$SERVICE_DIR/certs" "$SERVICE_DIR/chain" "$SERVICE_DIR/archive"; do
  pki_prepare_dir "$dir"
done

[[ -f "$KEY" ]] || pki_die "Service private key is missing; use platform-pki-service-issue first: $KEY"
archive_if_exists "$CERT" tls.crt
archive_if_exists "$CSR" tls.csr
archive_if_exists "$CHAIN" ca-chain.crt
archive_if_exists "$FULLCHAIN" fullchain.crt
archive_if_exists "$CONF" openssl.cnf

if [[ "$ROTATE_KEY" == 'true' ]]; then
  archive_if_exists "$KEY" tls.key
  openssl genpkey -algorithm EC -pkeyopt ec_paramgen_curve:secp384r1 -out "$KEY"
  pki_warn "Rotated service private key: $KEY"
else
  pki_info "Reusing existing service private key: $KEY"
fi
chmod 600 "$KEY"

pki_write_service_config "$CONF" "$COMMON_NAME" "$DNS_FILE" "$IPS_FILE"
chmod 600 "$CONF"

openssl req -config "$CONF" -key "$KEY" -new -sha384 -out "$CSR"
chmod 600 "$CSR"
CA_CMD=(openssl ca -batch -config "$PKI_DIR/intermediate-ca/openssl.cnf" -extfile "$CONF" -extensions server_cert -days "$DAYS" -notext -md sha384 -in "$CSR" -out "$CERT")
if [[ -n "$INTERMEDIATE_PASS_FILE" ]]; then
  CA_CMD+=(-passin "file:$INTERMEDIATE_PASS_FILE")
fi
"${CA_CMD[@]}"
chmod 644 "$CERT"
cat "$(pki_intermediate_cert)" "$(pki_root_cert)" >"$CHAIN"
cat "$CERT" "$(pki_intermediate_cert)" >"$FULLCHAIN"
chmod 644 "$CHAIN" "$FULLCHAIN"

bash "$SCRIPT_DIR/platform-pki-service-verify" "$SERVICE" --pki-dir "$PKI_DIR"
pki_ok "Renewed service certificate: $CERT"
